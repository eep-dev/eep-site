# Dependencies — installed fresh via npm ci in the image
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js — built inside the container
.next
out
build

# Tests / coverage (not used in production image)
coverage
.nyc_output

# Secrets and local env — never send in build context
.env
.env.*
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# VCS
.git
.gitignore
**/.git

# OS / editor / tooling
.DS_Store
Thumbs.db
.vscode
.idea
.cursor
*.swp
*.swo
*~

# Vercel / deploy metadata (not needed for standalone build)
.vercel

# TypeScript incremental / generated (Next regenerates on build)
*.tsbuildinfo
next-env.d.ts

# Compose and orchestration — not part of the app source build
compose.yml
compose.yaml
docker-compose.yml
docker-compose.yaml
docker-compose.*.yml
docker-compose.*.yaml

# Dev-only repo notes (not imported by the app)
AUDIT*.md
